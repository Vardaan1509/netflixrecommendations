# ─────────────────────────────────────────────────────────────
# Frontend environment variables (Vite)
# Copy this file to `.env` and fill in real values.
# Only VITE_-prefixed vars are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=your_supabase_url

# Supabase publishable/anon key (safe for the browser, protected by RLS)
# NOTE: the app reads this exact variable name in src/integrations/supabase/client.ts
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# ─────────────────────────────────────────────────────────────
# Edge Function secrets (NOT set here — configure in Supabase).
# These are server-side only and must NEVER be prefixed with VITE_
# or placed in this frontend .env. Set them with the Supabase CLI:
#   supabase secrets set OPENROUTER_API_KEY=... OPENROUTER_MODEL=google/gemini-3-flash-preview \
#     BACKBOARD_API_KEY=... BACKBOARD_ASSISTANT_ID=...
# or in the dashboard under Project Settings > Edge Functions > Secrets.
#
#   OPENROUTER_API_KEY     - OpenRouter: powers the questionnaire, the
#                            recommendations, AND embeddings
#                            (openai/text-embedding-3-small). One key covers all.
#   OPENROUTER_MODEL       - (optional) chat model slug for the questionnaire +
#                            recommendations. Defaults to google/gemini-3-flash-preview.
#                            Change it here to switch models without editing code.
#                            Cheaper: google/gemini-3.1-flash-lite
#                            More capable/stable: google/gemini-3.5-flash
#   BACKBOARD_API_KEY      - Backboard memory-powered assistant
#   BACKBOARD_ASSISTANT_ID - Backboard assistant id (backboard-feedback needs it)
# ─────────────────────────────────────────────────────────────
